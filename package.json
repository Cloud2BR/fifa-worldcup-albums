{
  "name": "fifa-worldcup-history-albums",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --outDir docs",
    "lint": "eslint .",
    "preview": "vite preview",
    "media:stadiums": "node scripts/download-stadium-images.mjs",
    "media:teams": "node scripts/download-team-images.mjs",
    "media:players": "node scripts/download-player-images.mjs --year 2026",
    "media:entities": "node scripts/download-entity-images.mjs",
    "media:index": "node scripts/build-media-index.mjs",
    "media:sync": "npm run media:stadiums && npm run media:teams && npm run media:entities && npm run media:players && npm run media:index"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "react": "19.2.6",
    "react-chartjs-2": "5.3.0",
    "react-dom": "19.2.6",
    "react-router-dom": "7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.22",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "vite": "8.0.16"
  }
}
